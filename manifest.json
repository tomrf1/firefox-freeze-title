{
  "manifest_version": 2,
  "name": "Freeze title",
  "version": "1.0",
  "description": "Prevents tab titles from updating",
  "permissions": ["menus", "tabs"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["index.js"]
    }
  ]
}

