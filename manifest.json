{
  "manifest_version": 2,
  "name": "Freeze title",
  "version": "2.0",
  "description": "Prevents tab titles from updating",
  "permissions": ["menus", "tabs"],
  "browser_specific_settings": {
    "gecko": {
      "id": "@freeze-title",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["index.js"]
    }
  ]
}

